PA_OPENAI_API_KEY=
PA_SOURCE_DB_URL=postgresql+psycopg://user:pass@localhost:5432/cursor
PA_OPERATIONAL_DB_URL=postgresql+psycopg://user:pass@localhost:5432/cursor
PA_GOOGLE_CLIENT_SECRETS_PATH=./client_secret.json

# Email notifications (optional — leave NOTIFICATIONS_ENABLED=false to disable)
PA_NOTIFICATIONS_ENABLED=false
PA_SMTP_HOST=smtp.gmail.com
PA_SMTP_PORT=587
PA_SMTP_USER=
PA_SMTP_PASSWORD=
PA_EMAIL_FROM=Portfolio Agent <you@gmail.com>

# Trigger API
PA_API_PORT=8000
# Static key checked via X-API-Key header. Leave empty to disable auth (dev only).
PA_API_KEY=change-me-before-deploying

PA_SLACK_WEBHOOK_URL=
PA_LANGSMITH_API_KEY=
